# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8080
ENVIRONMENT=development

# ============================================================================
# CONTAINER NAMES
# ============================================================================
API_CONTAINER_NAME=license-mgmt-api
POSTGRES_CONTAINER_NAME=license-mgmt-postgres
REDIS_CONTAINER_NAME=license-mgmt-redis

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=license_mgmt
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
POSTGRES_HOST_PORT=5432

# ============================================================================
# ADMIN USER CONFIGURATION
# ============================================================================
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.local
ADMIN_PASSWORD=your_secure_admin_password_here

# ============================================================================
# SECURITY & JWT CONFIGURATION
# ============================================================================
# Generate strong random secrets: openssl rand -base64 128 (or use a password generator)
JWT_SECRET=your_256bit_jwt_secret_here_generate_with_openssl_rand_base64_128
JWT_REFRESH_SECRET=your_256bit_jwt_refresh_secret_here_generate_with_openssl_rand_base64_128
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST_PORT=6379
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_DB=0

# ============================================================================
# SMTP / EMAIL CONFIGURATION
# ============================================================================
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password_here
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=License Management API
SMTP_ENABLE_SSL=true

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# CACHE TTL CONFIGURATION
# Flexible format support: "15min", "15 min" | "300sec", "300 sec" | "2h", "2 hours" | "7days", "7 days"
# ============================================================================
# Email & Token Verification
CACHE_TTL_EMAIL_VERIFICATION=24 hours
CACHE_TTL_PASSWORD_RESET=60 min

# Licensing & Dashboard
CACHE_TTL_LICENSE_ACTIVATION=15 min
CACHE_TTL_USER_LICENSES=10 min
CACHE_TTL_DASHBOARD_STATS=5 min

# Session Management
# Note: Access and Refresh token cache TTLs are derived from JWT_ACCESS_EXPIRY and JWT_REFRESH_EXPIRY
CACHE_TTL_USER_SESSION=24 hours
CACHE_TTL_LAST_SEEN_ACTIVITY=5 min

# ============================================================================
# RATE LIMITING CONFIGURATION
# Flexible format support (same as Cache TTL)
# ============================================================================
# LOGIN ENDPOINT
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_LOCKOUT_DURATION=15 min
RATE_LIMIT_LOGIN_RESET_WINDOW=15 min
RATE_LIMIT_LOGIN_AUTH_USER_MAX_ATTEMPTS=10
# Note: Authenticated users allowed 10 attempts (reduced risk)

# REGISTRATION ENDPOINT
RATE_LIMIT_REGISTER_MAX_ATTEMPTS=3
RATE_LIMIT_REGISTER_LOCKOUT_DURATION=30 min
RATE_LIMIT_REGISTER_RESET_WINDOW=1 hour
# Note: Stricter to prevent spam account creation

# PASSWORD RESET ENDPOINT
RATE_LIMIT_PASSWORD_RESET_MAX_ATTEMPTS=3
RATE_LIMIT_PASSWORD_RESET_LOCKOUT_DURATION=30 min
RATE_LIMIT_PASSWORD_RESET_RESET_WINDOW=1 hour

# EMAIL VERIFICATION ENDPOINT
RATE_LIMIT_EMAIL_VERIFY_MAX_ATTEMPTS=5
RATE_LIMIT_EMAIL_VERIFY_LOCKOUT_DURATION=15 min
RATE_LIMIT_EMAIL_VERIFY_RESET_WINDOW=15 min
# Note: More lenient for legitimate verification retries

# LICENSE ACTIVATION ENDPOINT
RATE_LIMIT_LICENSE_ACTIVATION_MAX_ATTEMPTS=10
RATE_LIMIT_LICENSE_ACTIVATION_LOCKOUT_DURATION=10 min
RATE_LIMIT_LICENSE_ACTIVATION_RESET_WINDOW=1 hour
# Note: More lenient for authenticated users activating licenses

# GENERAL API REQUESTS
RATE_LIMIT_API_MAX_ATTEMPTS=100
RATE_LIMIT_API_LOCKOUT_DURATION=1 min
RATE_LIMIT_API_RESET_WINDOW=1 min

# GRADUAL BACKOFF CONFIGURATION
# Enable exponential backoff for repeat offenders
RATE_LIMIT_ENABLE_BACKOFF=true
RATE_LIMIT_BACKOFF_MULTIPLIER=2
# Progressive lockout: 1st violation = base duration, 2nd = base * 2, 3rd = base * 4, etc.
RATE_LIMIT_MAX_BACKOFF_MULTIPLIER=8
# Maximum cap: base_lockout_duration * 8 (e.g., 15min base → 2 hour max)
